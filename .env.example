# Copy to .env for local dev, and set these as Environment Variables in Vercel for production.

# --- Database (REQUIRED) ---
# Local dev uses the `prisma dev` server. In PRODUCTION this must be a CLOUD Postgres
# (Prisma Postgres cloud via `npx create-db`, Neon, Supabase, or Vercel Postgres) — Vercel
# cannot reach a localhost database. Use the pooled/direct connection string.
DATABASE_URL="postgres://user:password@host:5432/dbname?sslmode=require"

# Only needed by the Prisma CLI for `migrate` (shadow DB). Not required at runtime.
# SHADOW_DATABASE_URL="postgres://..."

# --- Auth (REQUIRED) ---
# Strong random secret used to sign sessions + hash OTPs. Generate a fresh one for prod:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-secret"

# When "true", OTP codes are shown on screen instead of sent by SMS (no provider needed).
# Keep "true" for the stakeholder demo so anyone can log in. Set "false" once Twilio is wired.
OTP_DEV_MODE="true"

# Canonical public URL. Set in prod so OAuth redirect URIs stay stable behind Vercel's proxy.
# NEXT_PUBLIC_APP_URL="https://nightfall.community"

# --- SMS OTP via Twilio (needed only when OTP_DEV_MODE="false") ---
# TWILIO_ACCOUNT_SID="AC..."
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM="+1..."                     # a Twilio sender number, OR use a messaging service:
# TWILIO_MESSAGING_SERVICE_SID="MG..."     # takes precedence over TWILIO_FROM

# --- Social login (optional; each button shows only when its pair is set) ---
# Google Cloud → Credentials → OAuth client (Web). Authorized redirect URI:
#   https://nightfall.community/api/auth/google/callback
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# Discord Developer Portal → your app → OAuth2. Redirect:
#   https://nightfall.community/api/auth/discord/callback
# DISCORD_CLIENT_ID=""
# DISCORD_CLIENT_SECRET=""

# --- Real integrations (add later — all optional; features degrade gracefully without them) ---
# LIVEKIT_URL="wss://your-project.livekit.cloud"
# LIVEKIT_API_KEY=""
# LIVEKIT_API_SECRET=""
# STRIPE_SECRET_KEY=""
# RAZORPAY_KEY_ID=""
# RAZORPAY_KEY_SECRET=""
